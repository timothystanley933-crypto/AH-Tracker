# ====== SkyCofl Smart Relist Dashboard - example config ======
# Copy to ".env" and fill in. Never commit your real .env.

# --- Identity / access ---
# Your Minecraft account UUID (with or without dashes). Used only to READ your
# public auctions from CoflNet. No login, no session token, no automation.
MC_UUID=

# Password to protect the dashboard. Leave blank to disable login (local only).
APP_PASSWORD=

# Optional: separate secret for signing the session cookie. Falls back to
# APP_PASSWORD if unset. Set a long random string in production.
SECRET_KEY=

# --- Data source (public, read-only CoflNet API) ---
COFL_BASE_URL=https://sky.coflnet.com
CHECK_INTERVAL_SECONDS=300

# --- Notifications (all optional) ---
# Master switch. Set to false (e.g. for local dev) to send NO phone/Discord
# messages at all - nothing gets blasted while you test locally.
NOTIFICATIONS_ENABLED=true
# On the very first sync of a fresh/empty DB, never alert about auctions that
# are already sold/expired. Strongly recommended to leave true.
FIRST_SYNC_SUPPRESS_SOLD_ALERTS=true
DISCORD_WEBHOOK=
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
PUSHOVER_SOUND=cashregister
PUSHOVER_PRIORITY=1

# --- Economics / taxes ---
# Sales tax is taken from the SALE price when an item sells (1%).
# Listing fee is taken UP FRONT every time you list/relist an item (2.5%).
AH_SALES_TAX_RATE=0.01
AH_LISTING_FEE_RATE=0.025
# Legacy single-tax variable. Still read as the sales-tax fallback if
# AH_SALES_TAX_RATE is not set. Prefer the two variables above.
# AH_TAX_RATE=0.02

# Price-wall detection: N+ listings clustered within X% counts as a wall.
PRICE_WALL_WINDOW_PERCENT=1.0
PRICE_WALL_MIN_LISTINGS=3

# --- Comparable pricing engine ---
RELIST_COMPARABLE_ONLY=true
RELIST_COMPARABLE_PAGES=8
RELIST_MIN_COMPARABLE_MATCHES=2
RELIST_MIN_COMPARABLE_SCORE=75
RELIST_PET_LEVEL_TOLERANCE=5
RELIST_STAR_TOLERANCE=0
RELIST_GEMSTONE_TOLERANCE=0.80
RELIST_UNDERCUT_PERCENT=0.20
RELIST_UNDERCUT_COINS=10000

# RELIST vs HOLD: only relist when the gap is worth it AND the market supports it.
RELIST_PRICE_GAP_PERCENT=5
RELIST_PRICE_GAP_COINS=250000
RELIST_DECENT_VOLUME_PER_DAY=3
RELIST_STRONG_DOWN_TREND_24H=-3
RELIST_STRONG_UP_TREND_24H=5

# --- Profit thresholds & alerts ---
RELIST_MIN_PROFIT_AFTER_TAX=250000
RELIST_MIN_PROFIT_PERCENT_AFTER_TAX=2
RELIST_ALERT_COOLDOWN_MINUTES=60
RELIST_ALERT_DECISIONS=RELIST,CUT_LOSS,PROFIT_LOW,INCOMPARABLE

# --- Undercut / cheaper comparable alerts ---
# Advisory only: uses same-tag active BINs plus feature comparison, not raw LBIN.
UNDERCUT_ALERTS=true
UNDERCUT_CHECK_ENABLED=true
UNDERCUT_MIN_GAP_COINS=250000
UNDERCUT_MIN_GAP_PERCENT=3
UNDERCUT_MIN_COMPARABLE_SCORE=75
UNDERCUT_BETTER_ITEM_SCORE=85
UNDERCUT_COOLDOWN_MINUTES=60
UNDERCUT_MAX_CANDIDATES_TO_CHECK=60
UNDERCUT_INCLUDE_POSSIBLE=false
UNDERCUT_NOTIFY_DECISIONS=ACTIVE,HOLD,RELIST,PROFIT_LOW,INCOMPARABLE

# Only alert on INCOMPARABLE for items worth at least this much (coins).
INCOMPARABLE_ALERT_THRESHOLD=1000000

SOLD_ALERTS=true
RELIST_ALERTS=true
STARTUP_MESSAGE=false

# Consecutive missed syncs before a vanished active auction is marked STALE.
STALE_AFTER_MISSED_SYNCS=2

# --- Storage ---
# Local dev default below. On Railway use a mounted volume, e.g. /app/data/app.db
DATABASE_PATH=data/app.db
